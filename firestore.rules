rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isActivityHost(activityId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/activities/$(activityId))
        && get(/databases/$(database)/documents/activities/$(activityId)).data.hostId == request.auth.uid;
    }

    function isParticipant(activityId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/activities/$(activityId))
        && request.auth.uid in get(/databases/$(database)/documents/activities/$(activityId)).data.participants;
    }

    // ─── Users ───────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Users cannot delete their own document directly
    }

    // ─── Activities ──────────────────────────────────────────
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.hostId == request.auth.uid;
      allow update: if isActivityHost(activityId)
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['participants', 'currentParticipants', 'reactions']));
      allow delete: if isActivityHost(activityId);
    }

    // ─── Messages (sub-collection of activities) ─────────────
    match /activities/{activityId}/messages/{messageId} {
      allow read: if isParticipant(activityId) || isActivityHost(activityId);
      allow create: if (isParticipant(activityId) || isActivityHost(activityId))
        && request.resource.data.senderId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Notifications ───────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ─── Deny everything else ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
