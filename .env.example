# ============================================================
# JoinUp — Supabase Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Get your keys from: https://supabase.com/dashboard → Project Settings → API
# ============================================================

# --- Expo App (React Native) ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your_publishable_key_here

# --- Supabase Project Info ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Service Role Key (NEVER expose to client — server/edge functions only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Database Connection ---
DATABASE_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres

# --- ORM / Prisma Connection Strings ---
ORM_DATABASE_URL="postgresql://postgres.your-project-id:your_password@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
ORM_DIRECT_URL="postgresql://postgres.your-project-id:your_password@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# --- Next.js (if ever needed) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key_here
